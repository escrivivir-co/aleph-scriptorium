{
	// ============================================
	// COPILOT: SETTINGS DEL WORKSPACE SCRIPTORIUM
	// ============================================
	// Estos settings habilitan la detección de prompts e instructions
	// desde las carpetas de plugins además de las canónicas.
	// 
	// Documentación oficial:
	// - https://code.visualstudio.com/docs/copilot/customization/prompt-files
	// - https://code.visualstudio.com/docs/copilot/customization/custom-instructions
	// --- INSTRUCCIONES DE CÓDIGO ---
	// Habilitar archivos de instrucciones personalizadas
	"github.copilot.chat.codeGeneration.useInstructionFiles": false,
	// --- PROMPTS ADICIONALES ---
	// Añadir carpetas de prompts de plugins a las ubicaciones de búsqueda
	// Por defecto, VS Code solo detecta .github/prompts/
	"chat.promptFilesLocations": {
		".github/prompts": false,
		// --- Core plugins ---
		".github/plugins/scriptorium-pack/prompts": false,
		".github/plugins/arg-board/prompts": false,
		".github/plugins/agent-creator/prompts": false,
		".github/plugins/teatro/prompts": false,
		".github/plugins/scrum/prompts": false,
		".github/plugins/foro-scraper/prompts": false,
		".github/plugins/enciclopedia/prompts": false,
		".github/plugins/gh-pages/prompts": false,
		".github/plugins/mcp-presets/prompts": false,
		".github/plugins/openasyncapi-editor/prompts": false,
		// --- Editor plugins ---
		".github/plugins/prolog-editor/prompts": false,
		".github/plugins/blockly-editor/prompts": false,
		".github/plugins/wire-editor/prompts": false,
		".github/plugins/hypergraph-editor/prompts": false,
		".github/plugins/n8n-editor/prompts": false,
		".github/plugins/typed-prompting/prompts": false,
		// --- App plugins ---
		".github/plugins/arg-board-app/prompts": false,
		".github/plugins/wiring-app/prompts": false,
		".github/plugins/novelist/prompts": false,
		".github/plugins/network/prompts": false,
		".github/plugins/lore-sdk/prompts": false,
		".github/plugins/vector-machine/prompts": false,
		"VectorMachineSDK/.github/prompts": false,

		
		// --- ONFALO ---
		".github/plugins/consejo-asesor/prompts": false,
		// --- REPL / Notebooks ---
		".github/plugins/nodejs-notebooks/prompts": false
	},
	// --- INSTRUCTIONS ADICIONALES ---
	// Añadir carpetas de instructions de plugins
	// Por defecto, VS Code solo detecta .github/instructions/
	"chat.instructionsFilesLocations": {
		".github/instructions": false,
		// --- Core plugins ---
		".github/plugins/scriptorium-pack/instructions": false,
		".github/plugins/arg-board/instructions": false,
		".github/plugins/agent-creator/instructions": false,
		".github/plugins/teatro/instructions": false,
		".github/plugins/scrum/instructions": false,
		".github/plugins/foro-scraper/instructions": false,
		".github/plugins/enciclopedia/instructions": false,
		".github/plugins/gh-pages/instructions": false,
		".github/plugins/mcp-presets/instructions": false,
		".github/plugins/openasyncapi-editor/instructions": false,
		// --- Editor plugins ---
		".github/plugins/prolog-editor/instructions": false,
		".github/plugins/blockly-editor/instructions": false,
		".github/plugins/wire-editor/instructions": false,
		".github/plugins/hypergraph-editor/instructions": false,
		".github/plugins/n8n-editor/instructions": false,
		".github/plugins/typed-prompting/instructions": false,
		// --- App plugins ---
		".github/plugins/arg-board-app/instructions": false,
		".github/plugins/wiring-app/instructions": false,
		".github/plugins/novelist/instructions": false,
		".github/plugins/network/instructions": false,
		".github/plugins/lore-sdk/instructions": false,
		".github/plugins/vector-machine/instructions": false,
		// --- ONFALO ---
		".github/plugins/consejo-asesor/instructions": false,
		// --- REPL / Notebooks ---
		".github/plugins/nodejs-notebooks/instructions": false
	},
	// --- AGENTS.MD ANIDADOS (experimental) ---
	// Permite buscar AGENTS.md en subcarpetas
	// Útil si añadimos AGENTS.md por plugin en el futuro
	"chat.useNestedAgentsMdFiles": false,
	// --- AGENTS.MD GLOBAL ---
	// Habilitar uso del archivo AGENTS.md en la raíz
	"chat.useAgentsMdFile": true,
	// --- RECOMENDACIONES DE PROMPTS ---
	// Mostrar prompts recomendados al iniciar una nueva sesión de chat
	"chat.promptFilesRecommendations": {
		".github/plugins/scriptorium-pack/prompts": false
	},
	// --- JEKYLL/RUBY (para desarrollo local del sitio) ---
	"files.associations": {
		"*.md": "markdown"
	},
	// --- EXCLUSIONES DE ARCHIVOS ---
	"files.exclude": {
		"**/.git": true,
		"**/node_modules": true,
		"docs/_site": true,
		"docs/vendor": true
	},
	// --- BÚSQUEDA ---
	"search.exclude": {
		"**/.git": true,
		"**/node_modules": true,		
		"docs/_site": true,
		"docs/vendor": true
	}
}