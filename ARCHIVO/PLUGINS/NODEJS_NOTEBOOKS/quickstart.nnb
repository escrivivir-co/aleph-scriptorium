        "| /demo-mcp-gallery | Notebook de exploracion MCPGallery |\n",
        "| /demo-bothub-sdk | Notebook de demo BotHubSDK + IACM |\n",
        "| /diagnostico-stack | Diagnostico exhaustivo del stack completo |\n",
        "| /crear-notebook | Crear un notebook personalizado |\n"
      ],
      "outputs": []
    }
