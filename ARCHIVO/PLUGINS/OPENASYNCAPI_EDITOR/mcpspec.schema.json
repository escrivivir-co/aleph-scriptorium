{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://escrivivir-co.github.io/aleph-scriptorium/ARCHIVO/PLUGINS/OPENASYNCAPI_EDITOR/mcpspec.schema.json",
  "title": "Scriptorium MCPSpec Schema",
  "description": "Canonical local descriptor for MCP server contracts in OpenAsyncAPI Editor. This is not the official MCP wire schema; it is a Scriptorium-level YAML contract aligned with official MCP primitives, capabilities, and SDK integrations.",
  "type": "object",
  "required": ["kind", "protocolVersion", "mcpVersion"],
  "anyOf": [
    {
      "required": ["info"]
    },
    {
      "required": ["name", "version"]
    }
  ],
  "properties": {
    "kind": {
      "const": "scriptorium-mcpspec",
      "description": "Discriminator for the Scriptorium-local MCP descriptor format."
    },
    "protocolVersion": {
      "type": "string",
      "description": "Official MCP protocol release identifier used as semantic anchor (for example, 2025-11-25)."
    },
    "mcpVersion": {
      "type": "string",
      "description": "Human-facing MCP label or local descriptor edition retained for compatibility with existing repository usage."
    },
    "name": {
      "type": "string",
      "description": "Legacy top-level alias for implementation name.",
      "deprecated": true
    },
    "version": {
      "type": ["string", "number"],
      "description": "Legacy top-level alias for implementation version.",
      "deprecated": true
    },
    "description": {
      "type": "string",
      "description": "Legacy top-level alias for implementation description.",
      "deprecated": true
    },
    "info": {
      "$ref": "#/definitions/Info"
    },
    "implementation": {
      "$ref": "#/definitions/Implementation"
    },
    "server": {
      "$ref": "#/definitions/ServerRuntime"
    },
    "transport": {
      "$ref": "#/definitions/LegacyTransport"
    },
    "capabilities": {
      "$ref": "#/definitions/Capabilities"
    },
    "expectedClientCapabilities": {
      "$ref": "#/definitions/ExpectedClientCapabilities"
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ToolDescriptor"
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ResourceDescriptor"
      }
    },
    "resourceTemplates": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ResourceTemplateDescriptor"
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PromptDescriptor"
      }
    },
    "components": {
      "type": "object",
      "description": "Reusable local schemas or component definitions referenced by tools/resources/prompts.",
      "additionalProperties": true
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PluginDescriptor"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Repository-specific metadata that is not part of the official MCP model.",
      "additionalProperties": true
    },
    "x-scriptorium": {
      "type": "object",
      "description": "Explicit namespace for Scriptorium-only extensions that do not map to official MCP fields.",
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "definitions": {
    "Info": {
      "type": "object",
      "required": ["title", "version"],
      "properties": {
        "title": {
          "type": "string"
        },
        "version": {
          "type": ["string", "number"]
        },
        "description": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string" },
            "email": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "Implementation": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "version": { "type": ["string", "number"] },
        "description": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "icons": {
          "type": "array",
          "items": { "$ref": "#/definitions/Icon" }
        }
      },
      "additionalProperties": true
    },
    "ServerRuntime": {
      "type": "object",
      "properties": {
        "port": { "type": ["integer", "string", "null"] },
        "transport": {
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/definitions/LegacyTransport" }
          ]
        },
        "baseClass": { "type": "string" },
        "config": { "type": ["string", "object", "null"] },
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        },
        "url": { "type": "string" }
      },
      "additionalProperties": true
    },
    "LegacyTransport": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      },
      "additionalProperties": true
    },
    "Capabilities": {
      "type": "object",
      "properties": {
        "experimental": {
          "type": "object",
          "additionalProperties": true
        },
        "logging": {
          "oneOf": [
            { "type": "boolean", "deprecated": true },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "completions": {
          "oneOf": [
            { "type": "boolean", "deprecated": true },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "prompts": {
          "$ref": "#/definitions/PromptCapability"
        },
        "resources": {
          "$ref": "#/definitions/ResourceCapability"
        },
        "tools": {
          "$ref": "#/definitions/ToolCapability"
        },
        "tasks": {
          "oneOf": [
            { "type": "boolean", "deprecated": true },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "healthChecks": {
          "type": "boolean",
          "deprecated": true,
          "description": "Legacy Scriptorium extension. Prefer documenting this under x-scriptorium."
        },
        "plugins": {
          "type": ["boolean", "object"],
          "deprecated": true,
          "description": "Legacy Scriptorium extension. Prefer documenting this under x-scriptorium."
        }
      },
      "additionalProperties": true
    },
    "PromptCapability": {
      "oneOf": [
        {
          "type": "boolean",
          "deprecated": true
        },
        {
          "type": "object",
          "properties": {
            "listChanged": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      ]
    },
    "ResourceCapability": {
      "oneOf": [
        {
          "type": "boolean",
          "deprecated": true
        },
        {
          "type": "object",
          "properties": {
            "subscribe": { "type": "boolean" },
            "listChanged": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      ]
    },
    "ToolCapability": {
      "oneOf": [
        {
          "type": "boolean",
          "deprecated": true
        },
        {
          "type": "object",
          "properties": {
            "listChanged": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      ]
    },
    "ExpectedClientCapabilities": {
      "type": "object",
      "properties": {
        "sampling": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "roots": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "elicitation": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "tasks": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "object", "additionalProperties": true }
          ]
        }
      },
      "additionalProperties": true
    },
    "ToolDescriptor": {
      "type": "object",
      "required": ["name", "inputSchema"],
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icons": {
          "type": "array",
          "items": { "$ref": "#/definitions/Icon" }
        },
        "inputSchema": {
          "type": "object",
          "description": "Canonical MCP Tool.inputSchema. Defaults to JSON Schema 2020-12 when $schema is omitted.",
          "additionalProperties": true
        },
        "outputSchema": {
          "type": "object",
          "description": "Canonical MCP Tool.outputSchema for structuredContent.",
          "additionalProperties": true
        },
        "output": {
          "type": "object",
          "description": "Legacy alias for outputSchema preserved for migration.",
          "deprecated": true,
          "additionalProperties": true
        },
        "execution": {
          "type": "object",
          "properties": {
            "taskSupport": {
              "type": "string",
              "enum": ["forbidden", "optional", "required"]
            }
          },
          "additionalProperties": true
        },
        "annotations": {
          "$ref": "#/definitions/ToolAnnotations"
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "input": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "_meta": {
          "type": "object",
          "additionalProperties": true
        },
        "x-scriptorium": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "ToolAnnotations": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "readOnlyHint": { "type": "boolean" },
        "destructiveHint": { "type": "boolean" },
        "idempotentHint": { "type": "boolean" },
        "openWorldHint": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "ResourceDescriptor": {
      "type": "object",
      "required": ["uri", "name"],
      "properties": {
        "uri": { "type": "string" },
        "name": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "mimeType": { "type": "string" },
        "size": { "type": "number" },
        "icons": {
          "type": "array",
          "items": { "$ref": "#/definitions/Icon" }
        },
        "annotations": {
          "$ref": "#/definitions/CommonAnnotations"
        },
        "_meta": {
          "type": "object",
          "additionalProperties": true
        },
        "x-scriptorium": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "ResourceTemplateDescriptor": {
      "type": "object",
      "required": ["uriTemplate", "name"],
      "properties": {
        "uriTemplate": { "type": "string" },
        "name": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "mimeType": { "type": "string" },
        "icons": {
          "type": "array",
          "items": { "$ref": "#/definitions/Icon" }
        },
        "annotations": {
          "$ref": "#/definitions/CommonAnnotations"
        },
        "_meta": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "PromptDescriptor": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icons": {
          "type": "array",
          "items": { "$ref": "#/definitions/Icon" }
        },
        "arguments": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PromptArgument"
          }
        },
        "_meta": {
          "type": "object",
          "additionalProperties": true
        },
        "annotations": {
          "$ref": "#/definitions/CommonAnnotations"
        }
      },
      "additionalProperties": true
    },
    "PromptArgument": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "CommonAnnotations": {
      "type": "object",
      "properties": {
        "audience": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Canonical MCP values are user/assistant. Additional legacy values are tolerated for migration."
        },
        "priority": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "lastModified": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "Icon": {
      "type": "object",
      "required": ["src"],
      "properties": {
        "src": { "type": "string" },
        "mimeType": { "type": "string" },
        "sizes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark"]
        }
      },
      "additionalProperties": true
    },
    "PluginDescriptor": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": ["string", "number"] },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  }
}
